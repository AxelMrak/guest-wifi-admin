# ============================================================================
# Router UBUS Configuration
# ============================================================================

# URL completa del endpoint UBUS del router
ROUTER_URL=http://192.168.0.1/ubus

# Credenciales del router
ROUTER_USERNAME=useradmin
ROUTER_PASSWORD=changeme

# Query params que el portal cautivo agrega a /ubus (opcionales)
# phoneId: identificador de dispositivo (provisto por el login HTTP del router)
# rid:     id de request (provisto por el login HTTP del router)
# Si están vacíos, no se agregan query params.
ROUTER_PHONE_ID=
ROUTER_RID=

# ============================================================================
# Server Configuration
# ============================================================================

# Puerto del servidor backend
SERVER_PORT=3001
